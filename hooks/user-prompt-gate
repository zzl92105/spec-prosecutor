#!/usr/bin/env bash

set -euo pipefail

PAYLOAD="$(cat || true)"

python3 - "$PAYLOAD" <<'PY'
import json
import os
import sys

TRIGGER = "启动sp"
BLOCK_REASON = f"Spec Prosecutor auto mode is armed, but this prompt does not contain the required trigger phrase: {TRIGGER}"
CONTEXT = (
    "The user explicitly armed Spec Prosecutor with the exact trigger phrase. "
    "Invoke the installed skill by name: $spec-prosecutor. "
    "Do not answer from scratch. "
    "If the prompt references one explicit Markdown PRD, review that document only. "
    "Do not broaden scope beyond the explicitly provided PRD."
)

raw_payload = sys.argv[1] if len(sys.argv) > 1 else ""

try:
    payload = json.loads(raw_payload) if raw_payload else {}
except Exception:
    sys.exit(0)

prompt = payload.get("prompt", "")
prompt_lower = prompt.lower()
mentions_skill = (
    "$spec-prosecutor" in prompt_lower or
    "spec prosecutor" in prompt_lower or
    "spec-prosecutor" in prompt_lower
)

if TRIGGER in prompt:
    print(json.dumps({
        "hookSpecificOutput": {
            "hookEventName": "UserPromptSubmit",
            "additionalContext": CONTEXT
        }
    }, ensure_ascii=False))
    sys.exit(0)

if mentions_skill:
    print(json.dumps({
        "decision": "block",
        "reason": BLOCK_REASON
    }, ensure_ascii=False))
    sys.exit(0)

sys.exit(0)
PY
